{
  "name": "keeper",
  "version": "0.0.0",
  "description": "Fold Claude Code hook events into a SQLite jobs projection via a long-running Bun reducer daemon",
  "private": true,
  "bin": {
    "keeper": "cli/keeper.ts"
  },
  "scripts": {
    "start": "exec bun run src/daemon.ts",
    "dev": "exec bun --watch run src/daemon.ts",
    "lint": "biome check --no-errors-on-unmatched babysitters cli src test",
    "typecheck": "tsc --noEmit",
    "test:fast": "bun test --parallel --timeout=30000 --path-ignore-patterns='test/ansi-to-styled.test.ts' --path-ignore-patterns='test/live-shell.test.ts' --path-ignore-patterns='test/integration.test.ts' --path-ignore-patterns='test/daemon.test.ts' --path-ignore-patterns='test/plan-worker.test.ts'",
    "test:slow": "bun test test/integration.test.ts test/daemon.test.ts test/plan-worker.test.ts",
    "test:opentui": "bun test test/ansi-to-styled.test.ts test/live-shell.test.ts",
    "test": "bun run test:fast && bun run test:slow && bun run test:opentui"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "^1",
    "bun-types": "^1.3.12",
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.3.0",
    "@parcel/watcher": "2.5.6"
  },
  "trustedDependencies": ["@parcel/watcher"]
}
