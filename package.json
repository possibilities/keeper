{
  "name": "keeper",
  "version": "0.0.0",
  "description": "Fold Claude Code hook events into a SQLite jobs projection via a long-running Bun reducer daemon",
  "private": true,
  "bin": {
    "keeper": "cli/keeper.ts"
  },
  "scripts": {
    "start": "exec bun run src/daemon.ts",
    "dev": "exec bun --watch run src/daemon.ts",
    "lint": "biome check --no-errors-on-unmatched cli src test",
    "assert-comment-only": "bun scripts/assert-comment-only.ts",
    "lint:retired-name": "bash scripts/lint-retired-name.sh",
    "lint:claude-md": "bun scripts/lint-claude-md.ts",
    "lint:skill-ids": "bun scripts/lint-skill-ids.ts",
    "lint:fast-tests": "bun scripts/lint-fast-tests.ts",
    "typecheck": "tsc --noEmit",
    "test:opentui": "bun test ./test/ansi-to-styled.test.ts ./test/live-shell.test.ts ./test/note-composer.test.ts ./test/dash-app.test.ts ./test/dash-shell.test.ts",
    "test:gate": "bun scripts/test-gate.ts --phase=root --timeout=10000",
    "test:slow-git": "bun scripts/test-gate.ts --phase=slow-git --timeout=60000",
    "test:slow-daemon": "bun scripts/test-gate.ts --phase=slow-daemon --timeout=60000",
    "test:bench-folds": "bun scripts/test-gate.ts --phase=bench-folds --timeout=60000",
    "test": "bun scripts/test-default.ts",
    "test:full": "bun scripts/test-full.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "^1",
    "@types/js-yaml": "4.0.9",
    "bun-types": "^1.3.12",
    "typescript": "^5"
  },
  "dependencies": {
    "@clerc/core": "1.3.1",
    "@clerc/plugin-completions": "1.3.1",
    "@js-temporal/polyfill": "0.5.1",
    "@opentui/core": "^0.3.0",
    "@parcel/watcher": "2.5.6",
    "js-yaml": "4.2.0",
    "yaml": "2.8.1",
    "zod": "^4.4.3"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
