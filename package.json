{
  "name": "keeper",
  "version": "0.0.0",
  "description": "Fold Claude Code hook events into a SQLite jobs projection via a long-running Bun reducer daemon",
  "private": true,
  "scripts": {
    "start": "exec bun run src/daemon.ts",
    "dev": "exec bun --watch run src/daemon.ts",
    "lint": "biome check --no-errors-on-unmatched src test",
    "typecheck": "tsc --noEmit",
    "test": "bun test --isolate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "^1",
    "bun-types": "^1.3.12",
    "typescript": "^5"
  }
}
