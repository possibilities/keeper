{
  "name": "keeper",
  "version": "0.0.0",
  "description": "Fold Claude Code hook events into a SQLite jobs projection via a long-running Bun reducer daemon",
  "private": true,
  "bin": {
    "keeper": "cli/keeper.ts"
  },
  "scripts": {
    "start": "exec bun run src/daemon.ts",
    "dev": "exec bun --watch run src/daemon.ts",
    "lint": "biome check --no-errors-on-unmatched cli src test",
    "assert-comment-only": "bun scripts/assert-comment-only.ts",
    "lint:retired-name": "bash scripts/lint-retired-name.sh",
    "lint:claude-md": "bun scripts/lint-claude-md.ts",
    "test:hygiene": "bun scripts/lint-no-real-git.ts",
    "typecheck": "tsc --noEmit",
    "test:opentui": "bun test test/ansi-to-styled.test.ts test/live-shell.test.ts test/dash-app.test.ts test/dash-shell.test.ts",
    "test": "bun scripts/test-gate.ts --timeout=10000 --path-ignore-patterns='plugins/**' --path-ignore-patterns='test/agent-tmux-launch-stripped-env.slow.test.ts' --path-ignore-patterns='test/agent-tmux-launch-timeout.slow.test.ts' --path-ignore-patterns='test/usage-picker-flock.slow.test.ts' --path-ignore-patterns='test/agent-self-invoke.slow.test.ts' --path-ignore-patterns='test/await-conditions.test.ts' --path-ignore-patterns='test/await.test.ts' --path-ignore-patterns='test/autopilot-worker.test.ts' --path-ignore-patterns='test/backup.test.ts' --path-ignore-patterns='test/builds-watch.test.ts' --path-ignore-patterns='test/builds-watchdog.test.ts' --path-ignore-patterns='test/collections.test.ts' --path-ignore-patterns='test/commit-work.test.ts' --path-ignore-patterns='test/daemon.test.ts' --path-ignore-patterns='test/db.test.ts' --path-ignore-patterns='test/dead-letter-worker.test.ts' --path-ignore-patterns='test/events-ingest-worker.test.ts' --path-ignore-patterns='test/events-writer.test.ts' --path-ignore-patterns='test/exit-watcher.test.ts' --path-ignore-patterns='test/exit-watcher-ffi.test.ts' --path-ignore-patterns='test/git-worker.test.ts' --path-ignore-patterns='test/git-worker-realgit.slow.test.ts' --path-ignore-patterns='test/git-boot-seed-realgit.slow.test.ts' --path-ignore-patterns='test/git-wrapper.slow.test.ts' --path-ignore-patterns='test/worktree-git-realgit.slow.test.ts' --path-ignore-patterns='test/autopilot-worktree-recovery-realgit.slow.test.ts' --path-ignore-patterns='test/commit-work-worktree-isolation-realgit.slow.test.ts' --path-ignore-patterns='test/tmux-control-worker.slow.test.ts' --path-ignore-patterns='test/usage-scrape-runner.slow.test.ts' --path-ignore-patterns='test/keeper-guard.slow.test.ts' --path-ignore-patterns='test/pair-panel.slow.test.ts' --path-ignore-patterns='test/integration.test.ts' --path-ignore-patterns='test/bus-worker.integration.test.ts' --path-ignore-patterns='test/keeper-cli.test.ts' --path-ignore-patterns='test/plan-contract.test.ts' --path-ignore-patterns='test/maintenance-worker.test.ts' --path-ignore-patterns='test/plan-worker.test.ts' --path-ignore-patterns='test/reclaim.test.ts' --path-ignore-patterns='test/server-worker.test.ts' --path-ignore-patterns='test/session-state.test.ts' --path-ignore-patterns='test/history-read-verbs.test.ts' --path-ignore-patterns='test/view-shell.test.ts' --path-ignore-patterns='test/wake-worker.test.ts' --path-ignore-patterns='test/ansi-to-styled.test.ts' --path-ignore-patterns='test/live-shell.test.ts' --path-ignore-patterns='test/dash-app.test.ts' --path-ignore-patterns='test/dash-shell.test.ts' && bun run test:opentui",
    "test:full": "bun scripts/test-gate.ts --timeout=10000 --path-ignore-patterns='plugins/**' --path-ignore-patterns='test/ansi-to-styled.test.ts' --path-ignore-patterns='test/live-shell.test.ts' --path-ignore-patterns='test/dash-app.test.ts' --path-ignore-patterns='test/dash-shell.test.ts' && bun run test:opentui"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "^1",
    "@types/js-yaml": "4.0.9",
    "bun-types": "^1.3.12",
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.3.0",
    "@parcel/watcher": "2.5.6",
    "js-yaml": "4.2.0",
    "yaml": "2.8.1",
    "zod": "^4.4.3"
  },
  "trustedDependencies": ["@parcel/watcher"]
}
