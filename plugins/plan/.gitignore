# Build artifacts
dist/
build/

# Bun / TypeScript hook toolchain (bun.lock is committed; node_modules is not)
node_modules/

# Plan runtime state (ephemeral; see .keeper/state/ contract)
.keeper/state/

# Project-scoped keeper-prompt runtime store
.promptctl/

# Sidecar markers stamped next to every keeper-prompt-rendered output
# (carry {_warning, source_template, sha256} for the check-generated guard).
**/*.managed-file-dont-edit

# Generated static agents (all rendered from template/agents/*.md.tmpl via
# keeper prompt render-plugin-templates, frontmatter model/effort injected from
# the host matrix agent_pins; each carries a _promptctl_path marker sidecar).
# Leading slash anchors this to plugins/plan/agents/ ONLY — never the sibling
# template/agents/ source tree.
/agents/

# Compiler-owned per-cell `work` plugins (published from
# template/agents/worker.md.tmpl into
# workers/<model>-<effort>/{.claude-plugin/plugin.json, agents/worker.md}, one
# plugin per cell of the required host matrix; each loads as the constant
# work:worker, selected at launch via --plugin-dir). The adjacent lock serializes
# manifest-last cohort publication.
workers/
/workers.keeper-prompt-claude.lock

# Generated skills (rendered from template/skills/*.md.tmpl;
# each SKILL.md carries _promptctl_path marker).
skills/work/

# macOS
.DS_Store
