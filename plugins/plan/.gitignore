# Build artifacts
dist/
build/

# Bun / TypeScript hook toolchain (bun.lock is committed; node_modules is not)
node_modules/

# Plan runtime state (ephemeral; see .keeper/state/ contract)
.keeper/state/

# Project-scoped keeper-prompt runtime store
.promptctl/

# Sidecar markers stamped next to every keeper-prompt-rendered output
# (carry {_warning, source_template, sha256} for the check-generated guard).
**/*.managed-file-dont-edit

# Generated agents (rendered from template/agents/*.md.tmpl via
# keeper prompt render-plugin-templates; carries _promptctl_path marker).
agents/practice-scout.md

# Generated per-cell `work` plugins (rendered from template/agents/worker.md.tmpl
# into workers/<model>-<effort>/{.claude-plugin/plugin.json, agents/worker.md},
# one plugin per cell of the required host matrix; each loads as the constant
# work:worker, selected at launch via --plugin-dir).
workers/

# Generated skills (rendered from template/skills/*.md.tmpl;
# each SKILL.md carries _promptctl_path marker).
skills/work/

# macOS
.DS_Store
