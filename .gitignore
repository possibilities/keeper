# Python
.venv/
__pycache__/
*.egg-info/
*.pyc
.pytest_cache/
.ruff_cache/

# Build artifacts
dist/
build/

# Planctl runtime state (ephemeral; see .planctl/state/ contract)
.planctl/state/

# Project-scoped promptctl runtime store
.promptctl/

# Rendered work-plugins (generated by promptctl render-plugin-templates from
# agent-templates/worker[-codex].md.tmpl into work-plugins/<tier>/agents/worker.md).
work-plugins/

# Generated agents (rendered from agent-templates/*.md.tmpl via
# promptctl render-plugin-templates; carries _promptctl_path marker).
agents/practice-scout.md

# Generated skills (rendered from skill-templates/*.md.tmpl;
# each SKILL.md carries _promptctl_path marker).
skills/work/
skills/queue/
skills/defer/

# macOS
.DS_Store
