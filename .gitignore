# Python
.venv/
__pycache__/
*.egg-info/
*.pyc
.pytest_cache/
.ruff_cache/

# Build artifacts
dist/
build/

# Planctl runtime state (ephemeral; see .planctl/state/ contract)
.planctl/state/

# Project-scoped promptctl runtime store
.promptctl/

# Rendered work-plugin agents (generated by promptctl render-plugin-templates
# from agent-templates/worker[-codex].md.tmpl into work-plugins/<tier>/agents/worker.md).
# Only the rendered agent is ignored — each tier's .claude-plugin/plugin.json
# manifest is committed source (the renderer requires it to pre-exist before it
# renders into the dir, and claude --plugin-dir needs it to load the worker agent).
work-plugins/*/agents/worker.md

# Generated agents (rendered from agent-templates/*.md.tmpl via
# promptctl render-plugin-templates; carries _promptctl_path marker).
agents/practice-scout.md

# Generated skills (rendered from skill-templates/*.md.tmpl;
# each SKILL.md carries _promptctl_path marker).
skills/work/
skills/queue/
skills/defer/

# macOS
.DS_Store
