{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "summary",
        "rationale",
        "severity_reason",
        "affected_paths",
        "evidence",
        "suggested_fix"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "severity_reason": {
          "type": "string",
          "minLength": 1
        },
        "affected_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "suggested_fix": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fatal",
    "fatal_reason",
    "tier_0",
    "tier_1",
    "tier_2",
    "tier_3"
  ],
  "properties": {
    "fatal": {
      "type": "boolean"
    },
    "fatal_reason": {
      "type": "string"
    },
    "tier_0": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    },
    "tier_1": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    },
    "tier_2": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    },
    "tier_3": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Finding"
      }
    }
  }
}
