<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchAgent template for the babysitters BUILDS sitter's scanner
  (babysitters/builds/watch.ts).

  This is a TEMPLATE, not an installed agent: keeper ships no `install` verb.
  See README.md "Install" for the manual symlink + `launchctl bootstrap` steps.

  What it does: every 5 minutes, runs the read-only `watch.ts --tick` scanner
  over buildbot's state.sqlite, diffs current CI reds against its own seen-state,
  and on each new red onset spawns the headless `babysitters:builds` COLLECTOR
  agent (loaded with `--plugin-dir <repo>/babysitters`) to write one followup
  file per failure under ~/.local/state/babysitters/builds/followups/. It pages
  NOTHING on the findings path — the human works the collected corpus offline via
  `/babysit-triage builds`. It is a PURE EXTERNAL OBSERVER: opens buildbot's DB
  read-only, never writes it, mints no synthetic events, performs no RPC. Its OWN
  binary, NOT a `keeper` subcommand.

  Paths are hard-coded absolute because launchd does NOT source your shell rc,
  so `bun` cannot be found by name. The values below assume:
    - bun installed via Homebrew on Apple Silicon: /opt/homebrew/bin/bun
      (Intel Macs: /usr/local/bin/bun — edit ProgramArguments + PATH below)
    - the repo checked out at /Users/mike/code/keeper
    - buildbot state.sqlite under /Users/mike/.local/state/buildbot/master
    - sitter seen-state + logs under /Users/mike/.local/state/babysitters/builds
  Edit these for your own username / arch before bootstrapping.

  PATH below MUST include /Users/mike/.local/bin: the collector path shells out
  to `claude`, which lives there and would otherwise be unfound (launchd inherits
  no login PATH). NOTE: unlike the performance sitter, the builds findings path
  never pages, so `botctl` is not required on the findings path (only the sibling
  watchdog pages).

  Periodic via StartInterval (300s), NOT KeepAlive — mixing the two defeats the
  interval (KeepAlive would restart the one-shot scanner immediately). The
  interval resets from process EXIT, so a hung tick would block all future
  ticks; the scanner's hard agent-timeout is the load-bearing guard against
  that. RunAtLoad fires one immediate pass at bootstrap; the scanner exits 0
  cleanly if the buildbot DB is missing/locked, so an early load is harmless.

  Install:
    ln -s "$PWD/plist/arthack.babysitter.builds.watch.plist" ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/arthack.babysitter.builds.watch.plist

  Uninstall:
    launchctl bootout gui/$(id -u)/arthack.babysitter.builds.watch
    rm ~/Library/LaunchAgents/arthack.babysitter.builds.watch.plist

  Failures are observable via:
    launchctl print gui/$(id -u)/arthack.babysitter.builds.watch
    /Users/mike/.local/state/babysitters/builds/watch.stderr
-->
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>arthack.babysitter.builds.watch</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/bin/bun</string>
		<string>run</string>
		<string>/Users/mike/code/keeper/babysitters/builds/watch.ts</string>
		<string>--tick</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/Users/mike/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
	</dict>
	<key>StartInterval</key>
	<integer>300</integer>
	<key>RunAtLoad</key>
	<true/>
	<key>ProcessType</key>
	<string>Background</string>
	<key>WorkingDirectory</key>
	<string>/Users/mike/code/keeper</string>
	<key>StandardOutPath</key>
	<string>/Users/mike/.local/state/babysitters/builds/watch.stdout</string>
	<key>StandardErrorPath</key>
	<string>/Users/mike/.local/state/babysitters/builds/watch.stderr</string>
</dict>
</plist>
